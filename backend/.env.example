# Postgres connection string (Supabase: Project Settings -> Database -> Connection string,
# "URI" tab, direct connection on port 5432 — not the pooler). Any special characters in the
# password must be percent-encoded (e.g. "?" -> "%3F").
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
JWT_SECRET=replace-with-a-random-40-plus-character-secret
WHATSAPP_GATEWAY_URL=http://localhost:3001
# Chave de API da AbacatePay (app.abacatepay.com -> Configurações ->
# Chaves de API) pra habilitar Pix de verdade. Vazio = modo mock (QR falso,
# nenhuma cobrança real) — aguardando o lojista criar a conta na AbacatePay
# e ceder a chave.
ABACATEPAY_API_KEY=
# Chave da Google Routes API (Google Cloud Console -> Routes API ativada
# -> Credenciais). Habilita rota real por rua respeitando trânsito/mão-e-
# contramão de verdade, tanto na navegação do motoboy quanto na otimização
# de ordem de entrega em lote. Vazio = cai pro OSRM (rota) e pro heurístico
# de distância em linha reta (lote) — aguardando o lojista assinar a API e
# ceder a chave.
GOOGLE_ROUTES_API_KEY=
# Shown to customers in the WhatsApp message sent when a pickup ("retirada")
# order becomes ready.
STORE_PICKUP_ADDRESS=Rua Exemplo, 123 - Centro, João Pessoa - PB
# Comma-separated list of frontend origins allowed to call this API.
CORS_ORIGINS=http://localhost:5173,https://sunset-tabas.vercel.app
